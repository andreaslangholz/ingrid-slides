# Copy to .env.local and fill in real values (ask platform team for your-env / your-namespace).
# Load before a Claude Code session: source .env.local && source scripts/ingrid-auth.sh

# Ingrid MCP server
MCP_SERVER_URL=https://metamcp.your-env.ingridcapacity.com/metamcp/your-namespace/mcp

# Keycloak — set these, then run: source scripts/ingrid-auth.sh
# The script opens your normal Ingrid browser login and exports INGRID_JWT automatically.
KEYCLOAK_URL=https://keycloak.your-env.ingridcapacity.com
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=portal_your_env
